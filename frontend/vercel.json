{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "redirects": [
    {
      "source": "/demo",
      "destination": "https://youtu.be/4dVdf7vVN-M",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://synthfocus-backend.onrender.com/api/:path*"
    },
    {
      "source": "/ws/:path*",
      "destination": "https://synthfocus-backend.onrender.com/ws/:path*"
    },
    {
      "source": "/sessions",
      "destination": "/index.html"
    }
  ]
}
